# Paperless-ngx
PAPERLESS_URL=https://paperless.example.com
PAPERLESS_API_KEY=your_paperless_api_key_here
PAPERLESS_PUBLIC_URL=https://paperless.example.com

# Domain (used in docker-compose labels + OIDC URL)
DOMAIN=example.com

# Auth – static fallback token (optional)
MCP_API_KEY=

# OIDC client secret (plaintext, must match hash in Authelia config)
OIDC_CLIENT_SECRET=your_oidc_client_secret_here
